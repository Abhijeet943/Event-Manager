{"ast":null,"code":"import{useState,useEffect}from'react';export const useDebounce=function(value){let delay=arguments.length>1&&arguments[1]!==undefined?arguments[1]:500;const[debouncedValue,setDebouncedValue]=useState(value);useEffect(()=>{const handler=setTimeout(()=>{setDebouncedValue(value);},delay);return()=>clearTimeout(handler);},[value,delay]);return debouncedValue;};","map":{"version":3,"names":["useState","useEffect","useDebounce","value","delay","arguments","length","undefined","debouncedValue","setDebouncedValue","handler","setTimeout","clearTimeout"],"sources":["D:/project/Event-Manager/event-manager-ui/src/hooks/useDebounce.js"],"sourcesContent":["import { useState, useEffect } from 'react';\n\nexport const useDebounce = (value, delay = 500) => {\n  const [debouncedValue, setDebouncedValue] = useState(value);\n\n  useEffect(() => {\n    const handler = setTimeout(() => {\n      setDebouncedValue(value);\n    }, delay);\n\n    return () => clearTimeout(handler);\n  }, [value, delay]);\n\n  return debouncedValue;\n};\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAE3C,MAAO,MAAM,CAAAC,WAAW,CAAG,QAAAA,CAACC,KAAK,CAAkB,IAAhB,CAAAC,KAAK,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,GAAG,CAC5C,KAAM,CAACG,cAAc,CAAEC,iBAAiB,CAAC,CAAGT,QAAQ,CAACG,KAAK,CAAC,CAE3DF,SAAS,CAAC,IAAM,CACd,KAAM,CAAAS,OAAO,CAAGC,UAAU,CAAC,IAAM,CAC/BF,iBAAiB,CAACN,KAAK,CAAC,CAC1B,CAAC,CAAEC,KAAK,CAAC,CAET,MAAO,IAAMQ,YAAY,CAACF,OAAO,CAAC,CACpC,CAAC,CAAE,CAACP,KAAK,CAAEC,KAAK,CAAC,CAAC,CAElB,MAAO,CAAAI,cAAc,CACvB,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}